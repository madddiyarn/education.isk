generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  MODERATOR
  TEACHER
  METHODIST
  STUDENT
}

enum AssessmentType {
  SOR
  SOCH
}

model User {
  id                 String              @id @default(cuid())
  fullName           String
  login              String              @unique
  passwordHash       String
  role               Role
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  studentProfile     StudentProfile?
  teacherAssignments TeacherAssignment[] @relation("TeacherAssignments")

  @@index([role])
}

model Class {
  id                 String              @id @default(cuid())
  name               String              @unique
  studentProfiles    StudentProfile[]
  teacherAssignments TeacherAssignment[]
  assessmentSettings AssessmentSetting[]
  assessments        Assessment[]
}

model Subject {
  id                 String              @id @default(cuid())
  name               String              @unique
  teacherAssignments TeacherAssignment[]
  assessmentSettings AssessmentSetting[]
  assessments        Assessment[]
}

model StudentProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  classId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  class     Class    @relation(fields: [classId], references: [id], onDelete: Restrict)
  grades    Grade[]

  @@index([classId])
}

model TeacherAssignment {
  id        String  @id @default(cuid())
  teacherId String
  subjectId String
  classId   String
  teacher   User    @relation("TeacherAssignments", fields: [teacherId], references: [id], onDelete: Cascade)
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId, classId])
  @@index([teacherId])
  @@index([subjectId, classId])
}

model AssessmentSetting {
  id        String  @id @default(cuid())
  quarter   Int
  subjectId String
  classId   String
  sorCount  Int
  sochCount Int
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([quarter, subjectId, classId])
  @@index([classId, subjectId, quarter])
}

model Assessment {
  id        String         @id @default(cuid())
  type      AssessmentType
  number    Int
  quarter   Int
  subjectId String
  classId   String
  maxScore  Float
  subject   Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class     Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  grades    Grade[]

  @@unique([type, number, quarter, subjectId, classId])
  @@index([classId, subjectId, quarter])
}

model Grade {
  id           String         @id @default(cuid())
  studentId    String
  assessmentId String
  score        Float
  percentage   Float
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  student      StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assessment   Assessment     @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([studentId, assessmentId])
  @@index([assessmentId])
}
